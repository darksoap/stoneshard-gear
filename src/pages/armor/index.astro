---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ItemCard from '../../components/ItemCard.astro';
import FilterPanel from '../../components/FilterPanel.astro';
import SortSelect from '../../components/SortSelect.astro';
import { getCollection } from 'astro:content';
import { armorSlotLabels, armorSlotSlugs, armorClassLabels } from '../../i18n/zh';

const armor = await getCollection('armor');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const armorSlots = ['head', 'chest', 'arms', 'legs', 'waist', 'back'];
const jewelrySlots = ['ring', 'amulet'];

const slotCounts = armor.reduce((acc, a) => {
  acc[a.data.slot] = (acc[a.data.slot] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const armorSubcategories = Object.entries(slotCounts)
  .filter(([slot]) => armorSlots.includes(slot))
  .map(([slot, count]) => ({
    slot,
    slug: armorSlotSlugs[slot],
    label: armorSlotLabels[slot] || slot,
    count,
  }))
  .sort((a, b) => b.count - a.count);

const jewelrySubcategories = Object.entries(slotCounts)
  .filter(([slot]) => jewelrySlots.includes(slot))
  .map(([slot, count]) => ({
    slot,
    slug: armorSlotSlugs[slot],
    label: armorSlotLabels[slot] || slot,
    count,
  }))
  .sort((a, b) => b.count - a.count);

const availableFilters = {
  rarities: [...new Set(armor.map(a => a.data.rarity))],
  tiers: [...new Set(armor.map(a => a.data.tier))].sort((a, b) => a - b),
  materials: [...new Set(armor.map(a => a.data.material))],
  armorClasses: [...new Set(armor.map(a => a.data['class']))].filter(Boolean),
};

const itemsData = armor.map(a => ({
  id: a.id,
  data: a.data,
}));
---

<BaseLayout title="护甲与首饰" description={`护甲与首饰列表，共${armor.length}件`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white mb-2 tracking-wide">护甲与首饰</h1>
      <div class="section-divider max-w-xs mb-3"></div>
      <p class="text-text-secondary text-sm">共 <span id="total-count" class="text-accent-warm font-bold">{armor.length}</span> 件装备</p>
    </div>

    <div class="mb-6">
      {armorSubcategories.length > 0 && (
        <div class="mb-3">
          <div class="group-header mb-2">护甲</div>
          <div class="flex flex-wrap gap-2">
            {armorSubcategories.map((cat) => (
              <a
                href={`${base}/armor/${cat.slug}`}
                class="inline-flex items-center gap-2 px-3 py-1.5 bg-bg-secondary border border-border-dark rounded-full text-sm text-text-secondary hover:border-accent hover:text-accent transition-all"
              >
                <span>{cat.label}</span>
                <span class="text-text-muted text-xs">{cat.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
      {jewelrySubcategories.length > 0 && (
        <div>
          <div class="group-header mb-2">首饰</div>
          <div class="flex flex-wrap gap-2">
            {jewelrySubcategories.map((cat) => (
              <a
                href={`${base}/armor/${cat.slug}`}
                class="inline-flex items-center gap-2 px-3 py-1.5 bg-bg-secondary border border-border-dark rounded-full text-sm text-text-secondary hover:border-accent hover:text-accent transition-all"
              >
                <span>{cat.label}</span>
                <span class="text-text-muted text-xs">{cat.count}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <div class="flex flex-col lg:flex-row gap-6">
      <aside class="lg:w-56 flex-shrink-0">
        <FilterPanel itemType="armor" availableFilters={availableFilters} />
      </aside>

      <main class="flex-1 min-w-0">
        <div class="flex items-center justify-between mb-4 px-3 py-2 bg-bg-secondary border border-border-dark rounded-lg">
          <div class="text-text-muted text-xs">
            显示 <span id="filtered-count" class="text-accent font-bold text-sm">{armor.length}</span> 件
          </div>
          <SortSelect />
        </div>

        <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
          {itemsData.map((item) => (
            <div 
              class="item-card"
              data-slot={item.data.slot}
              data-rarity={item.data.rarity}
              data-tier={item.data.tier}
              data-material={item.data.material}
              data-armor-class={item.data['class'] || ''}
              data-name={item.data.nameZh}
              data-price={item.data.price}
              data-durability={item.data.durability}
            >
              <ItemCard
                id={item.data.id}
                name={item.data.name}
                nameZh={item.data.nameZh}
                rarity={item.data.rarity}
                tier={item.data.tier}
                image={item.data.image}
                href={`${base}/armor/${item.id}`}
              />
            </div>
          ))}
        </div>

        <div id="no-results" class="hidden text-center py-12 text-text-muted">
          没有找到符合条件的装备
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<script>
  import { initListFilter } from '../../scripts/list-filter';

  initListFilter({
    filterTypes: ['rarity', 'tier', 'material', 'armor-class'],
    urlParamMap: { rarity: 'rarity', tier: 'tier', material: 'material', 'armor-class': 'armorClass' },
    extraDataAttrs: { 'armor-class': 'armorClass' },
  });
</script>
