---
import { rarityLabels, materialLabels, armorClassLabels } from '../i18n/zh';

interface Props {
  itemType: 'weapons' | 'armor';
  availableFilters?: {
    rarities?: string[];
    tiers?: number[];
    materials?: string[];
    slots?: { value: string; label: string; count: number }[];
    armorClasses?: string[];
  };
}

const { itemType, availableFilters } = Astro.props;
---

<div class="filter-panel bg-bg-secondary border border-border-dark rounded-lg overflow-hidden">
  <div class="flex items-center justify-between p-4 bg-bg-tertiary border-b border-border-dark">
    <h3 class="text-white font-bold text-sm tracking-wider">筛选</h3>
    <button
      id="clear-filters"
      class="text-xs text-text-muted hover:text-accent transition-colors cursor-pointer"
    >
      清除全部
    </button>
  </div>

  <div class="p-4 space-y-4">
  {availableFilters?.slots && availableFilters.slots.length > 0 && (
    <div class="filter-group">
      <div class="group-header">类型</div>
      <div class="flex flex-wrap gap-1.5">
        <button
          data-filter-type="slot"
          data-value="all"
          class="filter-chip slot-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
        >
          全部
        </button>
        {availableFilters.slots.map((slot) => (
          <button
            data-filter-type="slot"
            data-value={slot.value}
            class="filter-chip slot-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
          >
            {slot.label} <span class="text-text-muted">{slot.count}</span>
          </button>
        ))}
      </div>
    </div>
  )}

  {availableFilters?.rarities && availableFilters.rarities.length > 0 && (
    <div class="filter-group">
      <div class="group-header">稀有度</div>
      <div class="flex flex-wrap gap-1.5">
        {availableFilters.rarities.map((rarity) => (
          <button
            data-filter-type="rarity"
            data-value={rarity}
            class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
          >
            {rarityLabels[rarity] || rarity}
          </button>
        ))}
      </div>
    </div>
  )}

  {availableFilters?.tiers && availableFilters.tiers.length > 0 && (
    <div class="filter-group">
      <div class="group-header">品质</div>
      <div class="flex flex-wrap gap-1.5">
        {availableFilters.tiers.map((tier) => (
          <button
            data-filter-type="tier"
            data-value={tier.toString()}
            class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
          >
            <span class="text-accent-warm">{'★'.repeat(tier)}</span>
          </button>
        ))}
      </div>
    </div>
  )}

  {availableFilters?.materials && availableFilters.materials.length > 0 && (
    <div class="filter-group">
      <div class="group-header">材质</div>
      <div class="flex flex-wrap gap-1.5">
        {availableFilters.materials.map((material) => (
          <button
            data-filter-type="material"
            data-value={material}
            class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
          >
            {materialLabels[material] || material}
          </button>
        ))}
      </div>
    </div>
  )}

  {availableFilters?.armorClasses && availableFilters.armorClasses.length > 0 && (
    <div class="filter-group">
      <div class="group-header">护甲类型</div>
      <div class="flex flex-wrap gap-1.5">
        {availableFilters.armorClasses.map((armorClass) => (
          <button
            data-filter-type="armor-class"
            data-value={armorClass}
            class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
          >
            {armorClassLabels[armorClass] || armorClass}
          </button>
        ))}
      </div>
    </div>
  )}
  </div>
</div>

<style>
  .filter-chip.active {
    background-color: rgba(90, 147, 221, 0.2);
    border-color: #5a93dd;
    color: #aecaee;
  }
</style>
