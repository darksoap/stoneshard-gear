---
import { rarityLabels, materialLabels, armorClassLabels } from "../i18n/zh";

interface Props {
  itemType: "weapons" | "armor" | "jewelry";
  availableFilters?: {
    rarities?: string[];
    tiers?: number[];
    materials?: string[];
    slots?: { value: string; label: string; count: number }[];
    armorClasses?: string[];
  };
}

const { itemType, availableFilters } = Astro.props;
---

<div
  class="filter-panel bg-bg-secondary border border-border-dark rounded-lg overflow-hidden"
  data-filter-panel
>
  <button
    type="button"
    class="filter-toggle w-full flex lg:hidden items-center justify-between p-4 bg-bg-tertiary border-b border-border-dark cursor-pointer"
    aria-expanded="false"
    aria-controls="filter-body"
  >
    <span
      class="text-white font-bold text-sm tracking-wider flex items-center gap-2"
    >
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        width="16"
        height="16"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
        ></path>
      </svg>
      筛选
    </span>
    <svg
      class="filter-chevron w-4 h-4 text-text-muted transition-transform"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 9l-7 7-7-7"></path>
    </svg>
  </button>

  <div
    class="hidden lg:flex items-center justify-between p-4 bg-bg-tertiary border-b border-border-dark"
  >
    <h3 class="text-white font-bold text-sm tracking-wider">筛选</h3>
    <button
      id="clear-filters"
      class="text-xs text-text-muted hover:text-accent transition-colors cursor-pointer"
    >
      清除全部
    </button>
  </div>

  <div id="filter-body" class="filter-body p-4 space-y-4 hidden lg:block">
    {
      availableFilters?.slots && availableFilters.slots.length > 0 && (
        <div class="filter-group">
          <div class="group-header">类型</div>
          <div class="flex flex-wrap gap-1.5">
            <button
              data-filter-type="slot"
              data-value="all"
              class="filter-chip slot-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
            >
              全部
            </button>
            {availableFilters.slots.map((slot) => (
              <button
                data-filter-type="slot"
                data-value={slot.value}
                class="filter-chip slot-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
              >
                {slot.label} <span class="text-text-muted">{slot.count}</span>
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      availableFilters?.rarities && availableFilters.rarities.length > 0 && (
        <div class="filter-group">
          <div class="group-header">稀有度</div>
          <div class="flex flex-wrap gap-1.5">
            {availableFilters.rarities.map((rarity) => (
              <button
                data-filter-type="rarity"
                data-value={rarity}
                class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
              >
                {rarityLabels[rarity] || rarity}
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      availableFilters?.tiers && availableFilters.tiers.length > 0 && (
        <div class="filter-group">
          <div class="group-header">品质</div>
          <div class="flex flex-wrap gap-1.5">
            {availableFilters.tiers.map((tier) => (
              <button
                data-filter-type="tier"
                data-value={tier.toString()}
                class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
              >
                <span class="text-accent-warm">{"★".repeat(tier)}</span>
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      availableFilters?.materials && availableFilters.materials.length > 0 && (
        <div class="filter-group">
          <div class="group-header">材质</div>
          <div class="flex flex-wrap gap-1.5">
            {availableFilters.materials.map((material) => (
              <button
                data-filter-type="material"
                data-value={material}
                class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
              >
                {materialLabels[material] || material}
              </button>
            ))}
          </div>
        </div>
      )
    }

    {
      availableFilters?.armorClasses &&
        availableFilters.armorClasses.length > 0 && (
          <div class="filter-group">
            <div class="group-header">护甲类型</div>
            <div class="flex flex-wrap gap-1.5">
              {availableFilters.armorClasses.map((armorClass) => (
                <button
                  data-filter-type="armor-class"
                  data-value={armorClass}
                  class="filter-chip px-2.5 py-1 rounded text-xs bg-bg-elevated border border-border-dark text-text-secondary hover:border-accent hover:text-accent transition-all cursor-pointer"
                >
                  {armorClassLabels[armorClass] || armorClass}
                </button>
              ))}
            </div>
          </div>
        )
    }
  </div>
</div>

<script>
  (function initFilterPanel() {
    const panel = document.querySelector("[data-filter-panel]");
    if (!panel) return;
    const toggle = panel.querySelector(".filter-toggle");
    const body = panel.querySelector("#filter-body");
    const chevron = panel.querySelector(".filter-chevron");
    if (!toggle || !body) return;

    const b = body as HTMLElement;
    const t = toggle as HTMLElement;

    function openPanel() {
      b.classList.remove("hidden");
      b.style.maxHeight = "0";
      b.style.overflow = "hidden";
      b.style.opacity = "0";
      requestAnimationFrame(() => {
        b.style.transition = "max-height 0.3s ease, opacity 0.25s ease";
        b.style.maxHeight = b.scrollHeight + "px";
        b.style.opacity = "1";
      });
    }

    function closePanel() {
      b.style.transition = "max-height 0.25s ease, opacity 0.2s ease";
      b.style.maxHeight = "0";
      b.style.opacity = "0";
      b.addEventListener(
        "transitionend",
        () => {
          b.classList.add("hidden");
          b.style.maxHeight = "";
          b.style.overflow = "";
          b.style.opacity = "";
          b.style.transition = "";
        },
        { once: true },
      );
    }

    t.addEventListener("click", () => {
      const isOpen = !b.classList.contains("hidden");
      if (isOpen) {
        closePanel();
      } else {
        openPanel();
      }
      t.setAttribute("aria-expanded", String(!isOpen));
      if (chevron) chevron.classList.toggle("rotate-180", !isOpen);
    });
  })();
</script>

<style>
  .filter-chip {
    position: relative;
  }

  .filter-chip.active {
    background-color: rgba(90, 147, 221, 0.2);
    border-color: #5a93dd;
    color: #aecaee;
    box-shadow:
      0 0 0 1px rgba(90, 147, 221, 0.3),
      0 0 8px rgba(90, 147, 221, 0.15);
  }

  .filter-chip.active::after {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    border: 1.5px solid rgba(90, 147, 221, 0.4);
    pointer-events: none;
    opacity: 1;
  }
</style>
