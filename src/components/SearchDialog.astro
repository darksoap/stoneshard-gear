---
---

<div id="search-backdrop" class="search-backdrop hidden" aria-hidden="true"></div>
<div id="search-dialog" class="search-dialog hidden" role="dialog" aria-modal="true" aria-label="搜索装备">
  <div class="search-dialog-inner">
    <div class="search-input-wrap">
      <svg class="search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" width="20" height="20">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索装备（中英文）..."
        autocomplete="off"
        autofocus
      />
      <kbd class="search-kbd">ESC</kbd>
    </div>
    <div id="search-results" class="search-results">
      <div class="search-empty">
        <p>输入关键词搜索装备</p>
        <p class="search-hint">支持中文名称、英文名称模糊搜索</p>
      </div>
    </div>
  </div>
</div>

<script>
  let fuseInstance = null;
  let indexLoaded = false;
  let loading = false;

  const backdrop = document.getElementById('search-backdrop')!;
  const dialog = document.getElementById('search-dialog')!;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsContainer = document.getElementById('search-results')!;

  function openSearch() {
    backdrop.classList.remove('hidden');
    dialog.classList.remove('hidden');
    backdrop.setAttribute('aria-hidden', 'false');
    input.value = '';
    input.focus();
    showEmpty();
  }

  function closeSearch() {
    backdrop.classList.add('hidden');
    dialog.classList.add('hidden');
    backdrop.setAttribute('aria-hidden', 'true');
    input.value = '';
  }

  function showEmpty() {
    resultsContainer.innerHTML = `
      <div class="search-empty">
        <p>输入关键词搜索装备</p>
        <p class="search-hint">支持中文名称、英文名称模糊搜索</p>
      </div>
    `;
  }

  function showLoading() {
    resultsContainer.innerHTML = `
      <div class="search-empty">
        <p>正在加载搜索索引...</p>
      </div>
    `;
  }

  function showNoResults() {
    resultsContainer.innerHTML = `
      <div class="search-empty">
        <p>未找到匹配的装备</p>
      </div>
    `;
  }

  async function loadIndex() {
    if (indexLoaded) return;
    if (loading) return;
    loading = true;
    showLoading();

    try {
      const FuseModule = await import('fuse.js');
      const FuseClass = FuseModule.default;

      const base = document.querySelector('base')?.getAttribute('href')?.replace(/\/$/, '') || '';
      const res = await fetch(`${base}/search-index.json`);
      const data = await res.json();

      fuseInstance = new FuseClass(data, {
        keys: [
          { name: 'nameZh', weight: 2 },
          { name: 'name', weight: 1.5 },
          { name: 'slotLabel', weight: 0.5 },
        ],
        threshold: 0.4,
        includeScore: true,
        minMatchCharLength: 1,
      });

      indexLoaded = true;
    } catch (err) {
      console.error('Failed to load search index:', err);
      resultsContainer.innerHTML = `
        <div class="search-empty">
          <p>搜索索引加载失败，请刷新页面重试</p>
        </div>
      `;
    } finally {
      loading = false;
    }
  }

  function renderResults(results: any[]) {
    if (results.length === 0) {
      showNoResults();
      return;
    }

    const html = results.slice(0, 20).map((result: any) => {
      const item = result.item;
      const rarityClass = item.rarity === 'unique' ? 'rarity-unique' : 'rarity-common';
      const rarityLabel = item.rarity === 'unique' ? '独一无二' : '普通';
      const tierStars = '★'.repeat(item.tier) + '☆'.repeat(5 - item.tier);

      return `
        <a href="${item.href}" class="search-result-item">
          <div class="search-result-info">
            <span class="search-result-name ${rarityClass}">${item.nameZh}</span>
            <span class="search-result-name-en">${item.name}</span>
          </div>
          <div class="search-result-meta">
            <span class="search-result-slot">${item.slotLabel}</span>
            <span class="search-result-tier">${tierStars}</span>
            <span class="search-result-rarity ${rarityClass}">${rarityLabel}</span>
          </div>
        </a>
      `;
    }).join('');

    resultsContainer.innerHTML = html;
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  async function handleSearch() {
    clearTimeout(debounceTimer);
    const query = input.value.trim();

    if (!query) {
      showEmpty();
      return;
    }

    debounceTimer = setTimeout(async () => {
      if (!indexLoaded) {
        await loadIndex();
      }

      if (!fuseInstance) return;

      const results = fuseInstance.search(query);
      renderResults(results);
    }, 200);
  }

  document.querySelectorAll('[data-search-trigger]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      openSearch();
    });
  });

  backdrop.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      if (dialog.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
      return;
    }

    if (e.key === 'Escape' && !dialog.classList.contains('hidden')) {
      closeSearch();
    }
  });

  input.addEventListener('input', handleSearch);

  resultsContainer.addEventListener('click', (e) => {
    const target = (e.target as HTMLElement).closest('a');
    if (target) {
      closeSearch();
    }
  });
</script>

<style>
  .search-backdrop {
    position: fixed;
    inset: 0;
    z-index: 99;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .search-dialog {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding-top: min(20vh, 120px);
  }

  .search-dialog.hidden,
  .search-backdrop.hidden {
    display: none;
  }

  .search-dialog-inner {
    width: 90vw;
    max-width: 560px;
    max-height: 70vh;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .search-input-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-border-dark);
  }

  .search-icon {
    flex-shrink: 0;
    color: var(--color-text-muted);
  }

  .search-input-wrap input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--color-text-primary);
    font-size: 1rem;
  }

  .search-input-wrap input::placeholder {
    color: var(--color-text-muted);
  }

  .search-kbd {
    flex-shrink: 0;
    padding: 2px 8px;
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    font-family: inherit;
  }

  .search-results {
    overflow-y: auto;
    padding: 8px;
    flex: 1;
  }

  .search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 32px 16px;
    color: var(--color-text-muted);
    text-align: center;
  }

  .search-empty p {
    margin: 0;
  }

  .search-hint {
    font-size: 0.8rem;
    margin-top: 4px !important;
    opacity: 0.7;
  }

  .search-result-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s;
    gap: 12px;
  }

  .search-result-item:hover,
  .search-result-item:focus {
    background-color: var(--color-bg-hover);
  }

  .search-result-info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .search-result-name {
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-name-en {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .search-result-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .search-result-slot {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background: var(--color-bg-tertiary);
    padding: 2px 6px;
    border-radius: 4px;
  }

  .search-result-tier {
    font-size: 0.7rem;
    color: var(--color-accent-warm);
    letter-spacing: -1px;
  }

  .search-result-rarity {
    font-size: 0.7rem;
  }

  .rarity-common {
    color: #e0e0e0;
  }

  .rarity-unique {
    color: #8248bc;
  }
</style>
